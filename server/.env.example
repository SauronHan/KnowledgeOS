# KnowledgeOS 环境变量配置模板

# 数据库与缓存配置
DATABASE_URL=postgresql://kos_admin:kos_password@localhost:5432/knowledgeos
REDIS_URL=redis://localhost:6380/0

# ================================
# LLM 多模型路由 API Keys (由 LiteLLM 统一接管)
# ================================

# Google Gemini (目前作为默认推荐)
GEMINI_API_KEY=your_gemini_api_key_here

# DeepSeek (高性价比、推理强，推荐作为 Step1 和私有化平替)
# 文档：https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Anthropic Claude (高智商，推荐作为 Step2 图谱推理)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI (通用备选)
OPENAI_API_KEY=your_openai_api_key_here

# OpenRouter (LLM 聚合平台，支持调用几乎所有开源/闭源模型)
# 文档：https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Ollama (完全本地化、隐私保护)
# 如果你在本机跑了 Ollama，请确保 `OLLAMA_API_BASE` 指向其地址
# OLLAMA_API_BASE=http://localhost:11434
